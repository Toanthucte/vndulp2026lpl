export type Topic = {
  id: string
  subject: 'Vật lý' | 'Sinh học'
  title: string
  summary: string
  accent: string
}

export type Flashcard = {
  id: string
  topicId: string
  front: string
  back: string
}

export type Question = {
  id: string
  topicId: string
  type:
    | 'multiple-choice'
    | 'short-answer'
    | 'fill-blank'
    | 'true-false'
    | 'matching'
    | 'essay-rubric'
  level: 'Nhận biết' | 'Thông hiểu' | 'Vận dụng'
  prompt: string
  answer: string
  explanation: string
  options?: string[]
  acceptedAnswers?: string[]
  statements?: Array<{
    id: string
    text: string
    answer: 'Đúng' | 'Sai'
  }>
  leftItems?: string[]
  rightItems?: string[]
  rubric?: Array<{
    score: '0.25' | '0.5' | '1.0'
    criteria: string
  }>
  format?: 'objective' | 'essay'
}

